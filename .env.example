# ============================================================================
# AgriTwin / tumbal.py — Environment Variables
# ============================================================================
# Copy file ini menjadi .env dan isi dengan nilai asli Anda.
#   cp .env.example .env
#
# Prioritas config: .env (env var) > agri_config.json > fallback default
# JANGAN commit file .env ke git!
# ============================================================================

# ── Cuaca ─────────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ── Geocoding & Maps ─────────────────────────────────────────────────────────
GEONAMES_USERNAME=
MAPBOX_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── LLM Settings (non-secret, bisa juga diatur via UI) ──────────────────────
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# LLM_TEMPERATURE=0.35
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# OLLAMA_MODEL=llama3.3
# OLLAMA_HOST=http://localhost:11434
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ── Telegram Notification ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_RECIPIENTS=
WHATSAPP_TEMPLATE_NAME=agri_alert
WHATSAPP_TEMPLATE_LANGUAGE=id
WHATSAPP_GRAPH_API_VERSION=v23.0

# ── Error Monitoring (Sentry — gratis 5K error/bulan, no CC) ────────────────
# Signup: sentry.io → Create Project (Python) → copy DSN
SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=agritwin@5.0

# ── Supabase (gratis 500MB, no CC) ──────────────────────────────────────────
# Signup: supabase.com → New Project → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── HiveMQ Cloud MQTT (gratis 100 koneksi, no CC) ──────────────────────────
# Signup: hivemq.com/mqtt-cloud-broker → Create Cluster
HIVEMQ_HOST=
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=
HIVEMQ_PASSWORD=

# ── CORS (production: ganti dengan domain Vercel Anda) ──────────────────────
# Contoh: CORS_ORIGINS=https://agritwin.vercel.app,https://agritwin.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Clerk Authentication (multi-user auth — clerk.com, gratis 10K MAU) ──────
# Signup: clerk.com → Create Application → copy keys
# Tambahkan NEXT_PUBLIC_* ke Vercel env vars, CLERK_SECRET_KEY ke Railway
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── PostHog Analytics (product analytics — posthog.com, gratis 1M events/bln) ─
# Signup: app.posthog.com → New Project → copy Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Midtrans Payment Gateway (Indonesia — sandbox.midtrans.com) ─────────────
# Signup: dashboard.midtrans.com/register → Settings → Access Keys
# Untuk testing: gunakan Sandbox keys (MIDTRANS_PRODUCTION=false)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_PRODUCTION=false
# MIDTRANS_FINISH_URL=https://agritwin.vercel.app/payment/success
# Midtrans webhook: signature dihitung dari SHA-512(order_id+status_code+gross_amount+SERVER_KEY)
# MIDTRANS_WEBHOOK_SECRET — dokumentasi saja, nilai sama dengan MIDTRANS_SERVER_KEY
MIDTRANS_WEBHOOK_SECRET=

# ── Clerk Webhook Secret (untuk validasi Svix signature) ─────────────────────
# Clerk Dashboard → Webhooks → Endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=
